# Server Configuration
PORT=3001
NODE_ENV=development

# JWT Secret - Change this to a random secure string in production!
JWT_SECRET=your_jwt_secret_here

# Optional: Gemini API key (can also be configured from admin panel)
# GEMINI_API_KEY=your_api_key_here

# SMTP Configuration for Contact Form Replies
# For Gmail: Use App Password (not your regular password)
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_NAME=Liceo Pedro Emilio Coll
SMTP_FROM_EMAIL=noreply@liceopedroemiliocoll.edu.ve
